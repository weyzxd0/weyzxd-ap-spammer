        local YouTag = Instance.new("TextLabel")
        YouTag.Parent = Card
        YouTag.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
        YouTag.Position = UDim2.new(1, -55, 0, 10)
        YouTag.Size = UDim2.new(0, 45, 0, 18)
        YouTag.Font = Enum.Font.GothamBold
        YouTag.Text = "SEN"
        YouTag.TextColor3 = Color3.fromRGB(255, 255, 255)
        YouTag.TextSize = 10
        YouTag.BorderSizePixel = 0

        local YouCorner = Instance.new("UICorner")
        YouCorner.CornerRadius = UDim.new(0, 6)
        YouCorner.Parent = YouTag
    end

    -- ═══════════════════════════════
    -- 💀 SPAMMER BUTONU
    -- ═══════════════════════════════
    local SpammerButton = Instance.new("TextButton")
    SpammerButton.Name = "SpammerButton"
    SpammerButton.Parent = Card
    SpammerButton.BackgroundColor3 = Color3.fromRGB(138, 43, 226)
    SpammerButton.Position = UDim2.new(0, 10, 0, 57)
    SpammerButton.Size = UDim2.new(1, -20, 0, 28)
    SpammerButton.Font = Enum.Font.GothamBlack
    SpammerButton.Text = "💀 SPAMMER"
    SpammerButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    SpammerButton.TextSize = 13
    SpammerButton.BorderSizePixel = 0
    SpammerButton.AutoButtonColor = true

    local SpamCorner = Instance.new("UICorner")
    SpamCorner.CornerRadius = UDim.new(0, 8)
    SpamCorner.Parent = SpammerButton

    local Gradient = Instance.new("UIGradient")
    Gradient.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromRGB(138, 43, 226)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(180, 60, 255)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(138, 43, 226))
    }
    Gradient.Parent = SpammerButton

    SpammerButton.MouseEnter:Connect(function()
        TweenService:Create(SpammerButton, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(170, 60, 255)}):Play()
    end)
    SpammerButton.MouseLeave:Connect(function()
        TweenService:Create(SpammerButton, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(138, 43, 226)}):Play()
    end)

    SpammerButton.MouseButton1Click:Connect(function()
        if spamming then
            spamming = false
            wait(0.3)
        end

        SpammerButton.Text = "🔥 SPAMLANIYOR..."
        SpammerButton.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
        InfoLabel.Text = "🎯 Hedef: " .. player.DisplayName .. " (@" .. player.Name .. ")"

        startSpam(player.Name)

        spawn(function()
            while spamming do wait(0.1) end
            SpammerButton.Text = "💀 SPAMMER"
            SpammerButton.BackgroundColor3 = Color3.fromRGB(138, 43, 226)
        end)
    end)

    return Card
end

-- Oyuncu listesini yenile
local function refreshPlayerList()
    for _, child in ipairs(ScrollFrame:GetChildren()) do
        if child:IsA("Frame") then
            child:Destroy()
        end
    end
    for _, player in ipairs(Players:GetPlayers()) do
        createPlayerCard(player)
    end
end

-- İlk yükleme
