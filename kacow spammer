-- Chat'e mesaj gönderme fonksiyonu (HIZLI)
local function sendChat(message)
    local success = pcall(function()
        game:GetService("ReplicatedStorage").DefaultChatSystemChatEvents.SayMessageRequest:FireServer(message, "All")
    end)
    
    if not success then
        pcall(function()
            local TextChatService = game:GetService("TextChatService")
            local channels = TextChatService:FindFirstChild("TextChannels")
            if channels then
                local rbxGeneral = channels:FindFirstChild("RBXGeneral")
                if rbxGeneral then
                    rbxGeneral:SendAsync(message)
                end
            end
        end)
    end
end

-- HIZLI Spammer fonksiyonu
local function startSpam(playerName)
    spamming = true
    StopButton.Visible = true
    
    local commands = {
        ";rocket " .. playerName,
        ";balloon " .. playerName,
        ";jumpscare " .. playerName,
        ";tiny " .. playerName
    }
    
    local repeatCount = tonumber(SpeedInput.Text) or 10
    
    spawn(function()
        for i = 1, repeatCount do
            if not spamming then break end
            for _, cmd in ipairs(commands) do
                if not spamming then break end
                sendChat(cmd)
                wait(0.15) -- ÇOK HIZLI - 0.15 saniye bekleme
            end
            if i < repeatCount then
                wait(0.05) -- Turlar arası neredeyse bekleme yok
            end
        end
        spamming = false
        StopButton.Visible = false
        InfoLabel.Text = "✅ Spam tamamlandı! Yeni hedef seç."
    end)
end

-- Oyuncu kartı oluşturma
local function createPlayerCard(player)
    local Card = Instance.new("Frame")
    Card.Name = "Card_" .. player.Name
    Card.BackgroundColor3 = Color3.fromRGB(35, 35, 50)
